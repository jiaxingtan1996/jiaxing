---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Jiaxing Tan',
  description = 'Notes on machine learning and references.',
  currentPath = '/'
} = Astro.props;

const isActive = (path: string) => currentPath === path;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main class="container">
      <header class="site-header">
        <a href="/" style="color: inherit; text-decoration: none;">
          <h1 class="site-title">Jiaxing Tan</h1>
        </a>
        <p class="site-subtitle">machine learning · references · notes</p>
        <nav class="nav" aria-label="Primary">
          <a href="/" class={isActive('/') ? 'active' : ''}>Home</a>
          <a href="/machine-learning/" class={isActive('/machine-learning/') ? 'active' : ''}>Machine Learning</a>
          <a href="/references/" class={isActive('/references/') ? 'active' : ''}>References</a>
        </nav>
      </header>
      <slot />
      <footer class="footer">
        Built with Astro + Markdown/MDX.
      </footer>
    </main>
  </body>
</html>
